# Project-level npm/pnpm config. Pinned to silence Vercel's environment
# leaking pnpm-specific keys into the npm warning stream.
#
# `loglevel=error` suppresses the "Unknown env config" warnings emitted
# when pnpm's `npm_config_*` env vars (npm-globalconfig,
# verify-deps-before-run, _jsr-registry) reach a plain-npm process. They
# are harmless warnings, not failures.
loglevel=error

# Strict pnpm settings — keeps installs deterministic on Vercel.
auto-install-peers=true
strict-peer-dependencies=false
